            if (type === viewType) {
                // 啟用點選的視圖樣式與顯示 Iframe
                btn.className = "px-4 py-2 rounded-lg bg-emerald-600 text-white shadow-sm transition-all";
                if (iframe) {
                    iframe.classList.remove('hidden');
                    iframe.classList.add('block');
