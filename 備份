        function renderHistoryArchive() {
            const container = document.getElementById('historyArchiveContainer');
            if (!meetingsData.length) {
                container.innerHTML = `<p class="text-xs text-emerald-700 font-mono p-6">目前尚無歷史存檔會議紀錄。</p>`;
                return;
            }

            const groups = {};
            meetingsData.forEach(m => {
                if (!groups[m.archive_group]) groups[m.archive_group] = [];
                groups[m.archive_group].push(m);
            });

            container.innerHTML = Object.keys(groups).map((groupName, idx) => `
                <details ${idx < 2 ? 'open' : ''} class="group border-b border-emerald-100/60 last:border-b-0">
                    <summary class="flex items-center justify-between px-6 py-4 bg-white/40 cursor-pointer hover:bg-emerald-50/50 transition-colors select-none">
                        <div class="flex items-center gap-2 text-sm font-bold text-emerald-950 font-mono">
