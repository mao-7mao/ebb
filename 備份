                            <span>${groupName}</span>
                        </div>
                        <span class="text-xs text-emerald-600 font-mono">${groups[groupName].length} 篇 Journal 歸檔</span>
                    </summary>
                    <div class="px-4 sm:px-6 py-2 bg-white/20 divide-y divide-emerald-100/40 text-sm">
                        ${groups[groupName].map(m => `
                            <div class="py-4 flex flex-col md:flex-row md:items-center justify-between gap-3 search-target" data-search="${m.search}">
                                <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4 flex-1 min-w-0">
                                    <span class="text-xs font-mono text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded sm:bg-transparent sm:p-0 shrink-0 w-fit">${m.date}</span>
                                    <span class="text-emerald-900 font-medium break-words leading-normal">"${m.title}"</span>
                                </div>
                                <div class="text-xs text-emerald-700 flex flex-wrap items-center gap-2 md:text-right shrink-0 font-mono pt-1 md:pt-0 border-t border-dashed border-emerald-100 md:border-0">
                                    <span>Speaker: <a href="#${m.speaker_id}" class="text-green-700 hover:underline font-medium">${m.speaker}</a></span>
                                    <span class="text-emerald-300 md:inline hidden">·</span>
                                    <span class="${m.status === 'archived' ? 'text-emerald-600 bg-emerald-50' : 'text-emerald-700 bg-emerald-100'} px-2 py-0.5 rounded font-semibold ml-auto md:ml-0">${m.status_label}</span>
                                </div>
                            </div>
                        `).join('')}
                    </div>
                </details>
            `).join('');
            lucide.createIcons();
        }

        document.addEventListener('DOMContentLoaded', () => {
            fetchAndInitLabSystem();

            const globalSearch = document.getElementById('globalSearch');
            globalSearch.addEventListener('input', (e) => {
                const query = e.target.value.toLowerCase().trim();
                if (!query) return;

                const searchTargets = document.querySelectorAll('.search-target');
                for (const target of searchTargets) {
                    const dataset = target.getAttribute('data-search').toLowerCase();
                    if (dataset.includes(query)) {
                        const parentDetails = target.closest('details');
                        if (parentDetails) parentDetails.open = true;

                        target.classList.remove('bg-emerald-100/40');
                        void target.offsetWidth; 
                        
                        const elementPosition = target.getBoundingClientRect().top + window.scrollY;
                        window.scrollTo({ top: elementPosition - 90, behavior: 'smooth' });
                        
                        target.classList.add('bg-emerald-100/40', 'border-emerald-400');
                        setTimeout(() => target.classList.remove('border-emerald-400'), 2000);
                        break;
                    }
                }
            });

            // 多重滾動高亮：同步更新側邊欄、頂部欄及手機底部導航
            const sideNavItems = document.querySelectorAll('.nav-item');
            const headerNavItems = document.querySelectorAll('.header-nav-item');
            const mobileNavItems = document.querySelectorAll('.mobile-nav-item');
            const sections = document.querySelectorAll('section');

            window.addEventListener('scroll', () => {
                let current = '';
                sections.forEach(section => {
                    if (window.scrollY >= section.offsetTop - 140) {
                        current = section.getAttribute('id');
                    }
                });

                // 1. 更新桌面側邊欄樣式
                sideNavItems.forEach(item => {
                    item.classList.remove('text-emerald-950', 'bg-emerald-100/50');
                    if (item.getAttribute('href') === `#${current}`) {
                        item.classList.add('text-emerald-950', 'bg-emerald-100/50');
                    }
                });

                // 2. 更新頂部導航樣式
                headerNavItems.forEach(item => {
                    item.classList.remove('text-emerald-950', 'bg-emerald-50');
                    if (item.getAttribute('href') === `#${current}`) {
                        item.classList.add('text-emerald-950', 'bg-emerald-50');
                    }
                });

                // 3. 更新手機底部導航高亮
                mobileNavItems.forEach(item => {
                    item.classList.remove('text-emerald-600', 'bg-emerald-50/80');
                    item.classList.add('text-emerald-800');
                    if (item.getAttribute('href') === `#${current}`) {
                        item.classList.remove('text-emerald-800');
                        item.classList.add('text-emerald-600', 'bg-emerald-50/80');
                    }
                });
            });
        });
    </script>
</body>
</html>

