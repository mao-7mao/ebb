    <script>
        let membersData = [];
        let meetingsData = [];

        async function fetchAndInitLabSystem() {
            try {
                const [membersRes, meetingsRes] = await Promise.all([
                    fetch('members.json'),
                    fetch('meetings.json')
                ]);
                membersData = await membersRes.json();
                meetingsData = await meetingsRes.json();
                renderMembers();
                renderHistoryArchive();
            } catch (error) {
                console.error("❌ 實驗室資料庫同步失敗！", error);
                document.getElementById('membersContainer').innerHTML = `<p class="text-red-700 font-mono text-sm">數據載入失敗，請確認伺服器狀態。</p>`;
            }
        }

        function renderMembers() {
            const container = document.getElementById('membersContainer');
            if (!membersData.length) return;

            container.innerHTML = membersData.map(m => {
                const keywordBadges = m.research_topic.keywords
                    ? m.research_topic.keywords.map(k => `<span class="text-[10px] bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-md border border-emerald-100/40">${k}</span>`).join('')
                    : '';
                const displayName = m.name_zh ? `${m.name_zh} <span class="text-xs font-normal text-emerald-600 font-mono ml-1">${m.name_en}</span>` : m.name_en;
                const descParts = m.description ? m.description.split(' / ') : ["目前尚無該主題之詳細文字介紹。", "No description available."];
                const descZh = descParts[0];
                const descEn = descParts[1] || '';
                const topicZh = m.research_topic.title_zh;
                const topicEn = m.research_topic.title_en ? m.research_topic.title_en : '';

                return `
                    <div id="${m.id}" class="border border-emerald-100/70 bg-white/60 backdrop-blur-sm rounded-2xl p-5 flex flex-col justify-between hover:border-emerald-400 hover:shadow-md hover:bg-white transition-all duration-300 search-target" data-search="${m.name_zh} ${m.name_en} ${m.role} ${m.research_topic.keywords.join(' ')}">
                        <div class="space-y-3.5">
                            <div class="flex items-start justify-between gap-2">
                                <div class="min-w-0">
                                    <h4 class="text-base font-bold text-emerald-950 truncate">${displayName}</h4>
                                    <p class="text-[11px] text-emerald-600 font-mono mt-0.5">${m.role}</p>
                                </div>
                                <span class="p-1.5 rounded-lg bg-emerald-50 text-emerald-600 shrink-0">
                                    <i data-lucide="book-open" class="w-4 h-4"></i>
                                </span>
                            </div>
                            <div class="bg-emerald-50/20 border border-emerald-100/30 rounded-xl p-3 space-y-2.5">
                                <div class="text-xs text-emerald-900 leading-relaxed font-semibold">
                                    <span class="text-emerald-600 font-bold text-[10px] tracking-wide uppercase block mb-0.5"> Research Topic</span>
                                    <span class="block text-emerald-950">${topicZh}</span>
                                    ${topicEn ? `<span class="block text-[11px] text-emerald-700/80 font-normal mt-0.5">${topicEn}</span>` : ''}
                                </div>
                                <div class="flex flex-wrap gap-1 pt-0.5">
                                    ${keywordBadges}
                                </div>
                                <div class="pt-2 border-t border-dashed border-emerald-200/60 leading-relaxed">
                                    <p class="text-[11px] text-emerald-850 font-normal">${descZh}</p>
                                    ${descEn ? `<p class="text-[10.5px] text-emerald-700/70 font-light mt-1 font-sans">${descEn}</p>` : ''}
                                </div>
                            </div>
                        </div>
                        <div class="mt-4 pt-3 border-t border-emerald-100/40 flex justify-between items-center text-xs text-emerald-700">
                            <a href="mailto:${m.links.email}" class="flex items-center gap-1 hover:text-emerald-950 transition-colors">
                                <i data-lucide="mail" class="w-3.5 h-3.5"></i> Email
                            </a>
                            <div>
                                ${m.links.scholar ? `<a href="${m.links.scholar}" class="flex items-center gap-1 hover:text-emerald-950 transition-colors"><i data-lucide="graduation-cap" class="w-3.5 h-3.5"></i> Scholar</a>` : ''}
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
            lucide.createIcons();
